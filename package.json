{
  "name": "api-automated-testing",
  "version": "2.0.0",
  "private": true,
  "license": "ISC",
  "description": "Postman Newman collections and JMeter performance pipeline",
  "scripts": {
    "postman": "bash utils/CollectionApi.sh",
    "postman:have-store": "bash utils/CollectionApi.sh PostmanScene/HaveStoreVersion",
    "postman:direct-store": "bash utils/CollectionApi.sh PostmanScene/DirectStoreVersion",
    "postman:no-store": "bash utils/CollectionApi.sh PostmanScene/NoStoreVersion",
    "postman:community": "bash utils/CollectionApi.sh PostmanScene/CommunityGroupBuying",
    "postman:baidu": "bash utils/CollectionApi.sh PostmanScene/BaiduDemo/BaiduHome.json",
    "jmeter": "bash utils/runJmeter.sh",
    "jmeter:report": "bash utils/generateJmeterReport.sh",
    "report": "TEST_TYPE=${TEST_TYPE:-local} bash utils/generateAllureResults.sh && bash utils/generateAllureReport.sh && TEST_TYPE=${TEST_TYPE:-local} bash utils/buildReportIndex.sh",
    "report:postman": "TEST_TYPE=postman npm run report",
    "report:jmeter": "TEST_TYPE=jmeter npm run report",
    "report:index": "TEST_TYPE=${TEST_TYPE:-local} bash utils/buildReportIndex.sh",
    "report:index:postman": "TEST_TYPE=postman npm run report:index",
    "report:index:jmeter": "TEST_TYPE=jmeter npm run report:index",
    "allure:results": "bash utils/generateAllureResults.sh",
    "allure:report": "bash utils/generateAllureResults.sh && bash utils/generateAllureReport.sh",
    "verify:local": "bash utils/verifyLocal.sh"
  },
  "dependencies": {
    "newman": "^6.2.2"
  },
  "devDependencies": {
    "allure-commandline": "^2.43.0"
  },
  "overrides": {
    "flatted": "^3.4.2",
    "handlebars": "^4.7.9",
    "jose": "^4.15.9",
    "lodash": "^4.18.1",
    "node-forge": "^1.4.0",
    "qs": "^6.15.3",
    "underscore": "^1.13.8",
    "uuid": "^11.1.0"
  }
}
