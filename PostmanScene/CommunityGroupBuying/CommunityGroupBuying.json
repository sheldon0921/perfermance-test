        {
          "name": "读取成员",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"response errcode is 0\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.errcode).to.eql(0);",
                  "});",
                  "pm.test(\"userid is yujia\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.userid).to.eql(\"yujia\");",
                  "});",
                  "pm.test(\"username is 程雨佳\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.name).to.eql(\"程雨佳\");",
                  "});",
                  "pm.test(\"user mobile is 13720729767\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.mobile).to.eql(\"13720729767\");",
                  "});",
                  "pm.test(\"user sex is 1\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.gender).to.eql(\"1\");",
                  "});",
                  ""
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.sendRequest(\"https://qyapi.weixin.qq.com/cgi-bin/gettoken?corpid=wwcd851624880f6f5b&corpsecret=UqnAYQUnf81LNVMDZDwhm1ehj3QP0wq_V9eXlGSvhrY\", function(err, response){",
                  "    pm.environment.set(\"accessToken\",response.json().access_token)",
                  "})",
                  ""
                ],
                "type": "text/javascript"
              }
            }
          ],
