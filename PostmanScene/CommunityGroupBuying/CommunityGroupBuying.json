      "item": [
        {
          "name": "获取accessToken",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Body matches string\", function () {",
                  "    pm.expect(pm.response.text()).to.include(\"expires_in\");",
                  "});",
                  "pm.test(\"errmsg is ok\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.errmsg).to.eql(\"ok\");",
                  "});",
                  "pm.test(\"expires_in is 7200\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.expires_in).to.eql(7201);",
                  "});",
                  "",
                  "",
                  "",
                  "",
                  "",
                  "",
                  "",
                  "",
                  "",
                  "",
                  "",
                  "//清除环境变量",
                  "// pm.environment.unset(\"accessToken\");",
                  "//清除全局变量",
                  "// pm.globals.unset(\"accessToken\")",
                  "// pm.globals.set(\"access_token\", response.jsonData().access_token)",
                  "",
                  "// pm.globals.unset(\"variable_key\"); 清除全局变量",
                  "// pm.environment.unset(\"variable_key\");  清除环境变量",
                  "// pm.globals.get(\"variable_key\");      获取全局变量",
                  "// pm.variables.get(\"variable_key\");    获取一个变量",
                  "// pm.environment.get(\"variable_key\");      获取环境变量",
                  "// pm.sendRequest(\"https://postman-echo.com/get\", function (err, response) {",
                  "//     console.log(response.json());",
                  "// });  发送一个请求",
                  "// pm.globals.set(\"variable_key\", \"variable_value\");  设置环境变量",
                  "",
                  "pm.sendRequest(\"https://qyapi.weixin.qq.com/cgi-bin/gettoken?corpid=wwcd851624880f6f5b&corpsecret=UqnAYQUnf81LNVMDZDwhm1ehj3QP0wq_V9eXlGSvhrY\", function(err, response){",
                  "    pm.environment.set(\"accessToken\",response.json().access_token)",
                  "})"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  ""
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://qyapi.weixin.qq.com/cgi-bin/gettoken?corpid=wwcd851624880f6f5b&corpsecret=UqnAYQUnf81LNVMDZDwhm1ehj3QP0wq_V9eXlGSvhrY",
              "protocol": "https",
              "host": [
                "qyapi",
                "weixin",
                "qq",
                "com"
              ],
              "path": [
                "cgi-bin",
                "gettoken"
              ],
              "query": [
                {
                  "key": "corpid",
                  "value": "wwcd851624880f6f5b"
                },
                {
                  "key": "corpsecret",
                  "value": "UqnAYQUnf81LNVMDZDwhm1ehj3QP0wq_V9eXlGSvhrY"
                }
              ]
            }
          },
          "response": []
