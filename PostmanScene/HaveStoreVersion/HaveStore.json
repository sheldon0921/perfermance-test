		{
			"name": "ConsoleLogin",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"//发了一个post请求",
							"",
							"// const loginRequest = {",
							"//     url:'https://crs-api.vchangyi.com/gw-scrm/login',",
							"//     method: 'POST',",
							"//     header: 'Content-Type: application/json',",
							"//     body:{",
							"//         mode: 'raw',",
							"//         raw:JSON.stringify({",
							"//             account: 'yangqiao@vchangyi.com',",
							"//             password: '445ac28dcfb325e80dc7fe91573632d1'",
							"//         })",
							"//     }",
							"// };",
							"// pm.sendRequest(loginRequest, function(err, response){",
							"//     pm.environment.set(\"token\",response.json().data.token)",
							"//     pm.environment.set(\"hash\",response.json().data.hash)",
							"// })",
							"var url=pm.request.url.toString()",
							"pm.test(url+\"的Statuscode 是 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"var requestJson= pm.request.body",
							"var responseJson= pm.response.json()",
							"pm.environment.set(\"token\", responseJson.data.token)",
							"pm.environment.set(\"hash\", responseJson.data.hash)",
							"console.log(\"请求参数：\", requestJson)",
							"console.log(\"request_id\", responseJson.request_id)"
						],
						"type": "text/javascript"
					}
				},
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"pm.environment.set(\"bgDomain\", \"crs-api.vchangyi.com\")"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"login_type\": 1,\n    \"account\": \"yangqiao@vchangyi.com\",\n    \"password\": \"445ac28dcfb325e80dc7fe91573632d1\"\n}",
