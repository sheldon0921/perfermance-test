pipeline {
    agent any
    options {
    		buildDiscarder(logRotator(numToKeepStr: '25'))
    		timestamps()
            timeout(time:30, unit:"MINUTES")
    	}
    stages {
        stage('Prepare'){
            steps{
                echo '初始化执行环境：安装依赖包和工具'
                sh 'python3 -m pip install pipenv'
                sh 'python3 -m pipenv install --skip-lock'
                sh 'rm -rf report/resultOnlinePlusNew && mkdir report/resultOnlinePlusNew'
                sh 'cp report/categories.json report/resultOnlinePlusNew/'
//                sh 'npm install'
            }
        }
        stage('Run Test Case') {
            failFast false
            steps {
            parallel(
                'Run Pytest Case': {
                    echo '执行py脚本中的先线上正确性校验场景'
//                    sh 'pipenv run pytest -v -n auto -capture=fd  --self-contained-html -p no:warnings --junit-xml=report/resultOnline/pytestout.xml'
                    sh 'pipenv run pytest -v -n auto -capture=fd -m onLineIndex --reruns 3 --reruns-delay 5 -p no:warnings --alluredir report/resultOnlinePlusNew'
                }
            )
            }
        }
    }
    post {
        always {
//            junit allowEmptyResults: true, testResults: 'report/resultOnline/*.xml'
//            allure includeProperties: false, jdk: '', results: [[path: 'report/resultOnline']]
            allure includeProperties: false, jdk: '', results: [[path: 'report/resultOnlinePlusNew']]
        }

        failure {
            emailext(
//                to: 'wangliping@vchangyi.com,zhangxin@vchangyi.com,mujunqiang@vchangyi.com,xuetong@vchangyi.com,baizhe@vchangyi.com,wangjianmin@vchangyi.com,houyingcai@vchangyi.com,hanzhigang@vchangyi.com,yangqiao@vchangyi.com,zhaojie@vchangyi.com,zhujiaqi@vchangyi.com,huangxiaomin@vchangyi.com,maxiongwei@vchangyi.com,hulongyang@vchangyi.com,wangzhou@vchangyi.com',
                to: 'mujunqiang@vchangyi.com,xuetong@vchangyi.com,baizhe@vchangyi.com',
                subject: '电商版线上监控脚本执行失败',
                body: '测试报告：http://ci.tools.vchangyi.com/view/%E8%87%AA%E5%8A%A8%E5%8C%96%E6%B5%8B%E8%AF%95%E5%B9%B3%E5%8F%B0/job/autotest/job/testing-for-online-retailers/${BUILD_ID}/allure/\n<br>'
                       +'\n<br>\n<br>'
                       +'构建路径：${BUILD_URL}\n<br>'
                )
        }
        success {
                 script {
                         currentBuild.description = "Success"
                        }
                }
        aborted {
                 script {
                         currentBuild.description = "Aborted"
                        }
                }
    }
}
