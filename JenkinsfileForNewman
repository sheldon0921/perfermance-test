pipeline {
    agent any
    environment {
        PATH = "/opt/homebrew/opt/node@22/bin:/opt/homebrew/opt/openjdk@21/bin:/opt/homebrew/bin:${env.PATH}"
    }
    options {
        buildDiscarder(logRotator(numToKeepStr: '25'))
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
    }
    parameters {
        string(
            name: 'COLLECTION_PATH',
            defaultValue: 'PostmanScene/BaiduDemo/BaiduHome.json',
            description: 'Postman collection 文件或目录；默认使用可本地稳定通过的 Baidu Demo'
        )
    }
    stages {
        stage('Prepare Reports') {
            steps {
                sh 'bash utils/cleanReports.sh postman'
            }
        }
        stage('Install') {
            steps {
                sh 'npm ci'
            }
        }
        stage('Run Newman') {
            steps {
                sh 'bash utils/CollectionApi.sh "${COLLECTION_PATH}"'
            }
        }
    }
    post {
        always {
            sh 'TEST_TYPE=postman bash utils/generateAllureResults.sh'
            sh 'bash utils/generateAllureReport.sh'
            sh 'TEST_TYPE=postman bash utils/buildReportIndex.sh'
            junit allowEmptyResults: true, testResults: 'report/result/*.xml'
            publishHTML target: [
                allowMissing: true,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'report/jenkins',
                reportFiles: 'index.html',
                reportName: 'Report Index'
            ]
            publishHTML target: [
                allowMissing: true,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'report/allure-report',
                reportFiles: 'index.html',
                reportName: 'Allure Report'
            ]
            archiveArtifacts allowEmptyArchive: true, artifacts: 'report/result/*.xml,report/newman/**,report/jenkins/**,report/allure-results/**,report/allure-report/**'
        }
    }
}
