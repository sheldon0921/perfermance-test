pipeline {
    agent any
    environment {
        PATH = "/opt/homebrew/opt/node@22/bin:/opt/homebrew/opt/openjdk@21/bin:/opt/homebrew/bin:${env.PATH}"
    }
    options {
        buildDiscarder(logRotator(numToKeepStr: '25'))
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
    }
    parameters {
        choice(
            name: 'TEST_TYPE',
            choices: ['postman', 'jmeter'],
            description: '选择执行 Newman 接口测试或 JMeter 性能测试'
        )
        string(
            name: 'COLLECTION_PATH',
            defaultValue: 'PostmanScene/BaiduDemo/BaiduHome.json',
            description: 'Postman collection 文件或目录；TEST_TYPE=postman 时生效'
        )
        string(
            name: 'CASE_FILE',
            defaultValue: 'script/simulate/baidu_home.jmx',
            description: 'JMeter jmx 脚本路径；TEST_TYPE=jmeter 时生效'
        )
        string(name: 'ThreadsCount', defaultValue: '1', description: 'JMeter 线程数')
        string(name: 'RampUp', defaultValue: '1', description: 'JMeter RampUp 秒数')
        string(name: 'time', defaultValue: '10', description: 'JMeter 持续时间，单位秒')
        string(name: 'ThinkTimeMs', defaultValue: '1000', description: 'JMeter 请求间隔，单位毫秒')
        string(name: 'TargetDomain', defaultValue: 'www.baidu.com', description: 'JMeter 目标域名')
        string(name: 'TargetProtocol', defaultValue: 'https', description: 'JMeter 协议')
        string(name: 'TargetPath', defaultValue: '/', description: 'JMeter 请求路径')
    }
    stages {
        stage('Prepare Reports') {
            steps {
                sh 'bash utils/cleanReports.sh local'
            }
        }
        stage('Install Node Dependencies') {
            steps {
                sh 'npm ci'
            }
        }
        stage('Run Newman') {
            when {
                expression { params.TEST_TYPE == 'postman' }
            }
            steps {
                sh 'bash utils/CollectionApi.sh "${COLLECTION_PATH}"'
            }
        }
        stage('Run JMeter') {
            when {
                expression { params.TEST_TYPE == 'jmeter' }
            }
            steps {
                sh 'env ThreadsCount="${ThreadsCount}" RampUp="${RampUp}" time="${time}" ThinkTimeMs="${ThinkTimeMs}" TargetDomain="${TargetDomain}" TargetProtocol="${TargetProtocol}" TargetPath="${TargetPath}" bash utils/runJmeter.sh "${CASE_FILE}"'
            }
        }
    }
    post {
        always {
            sh 'TEST_TYPE="${TEST_TYPE}" bash utils/generateAllureResults.sh'
            sh 'bash utils/generateAllureReport.sh'
            sh 'TEST_TYPE="${TEST_TYPE}" bash utils/buildReportIndex.sh'
            script {
                if (fileExists('report/result')) {
                    junit allowEmptyResults: true, testResults: 'report/result/*.xml'
                }
            }
            publishHTML target: [
                allowMissing: true,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'report/jenkins',
                reportFiles: 'index.html',
                reportName: 'Report Index'
            ]
            publishHTML target: [
                allowMissing: true,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'report/allure-report',
                reportFiles: 'index.html',
                reportName: 'Allure Report'
            ]
            publishHTML target: [
                allowMissing: true,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'report/report',
                reportFiles: 'index.html',
                reportName: 'JMeter Dashboard'
            ]
            archiveArtifacts allowEmptyArchive: true, artifacts: 'report/result/*.xml,report/newman/**,report/jtlResult.jtl,report/report/**,report/jenkins/**,report/allure-results/**,report/allure-report/**'
        }
    }
}
